{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neptune-media-webtv",
  "main": "neptune-tv-media-cloudflare/src/entry-v4.js",
  "compatibility_date": "2026-07-16",
  "workers_dev": true,
  "triggers": {
    "crons": ["17 * * * *"]
  },
  "assets": {
    "directory": "./neptune-tv-media-cloudflare/public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/",
      "/studio/*",
      "/api/*",
      "/media/*",
      "/direct/*",
      "/emissions/*",
      "/programmes/*",
      "/mentions-legales/*",
      "/confidentialite/*",
      "/contact/*",
      "/robots.txt",
      "/sitemap.xml",
      "/video-sitemap.xml",
      "/llms.txt"
    ]
  },
  "durable_objects": {
    "bindings": [
      { "name": "STUDIO", "class_name": "StudioStore" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["StudioStore"] }
  ],
  "r2_buckets": [
    { "binding": "MEDIA", "bucket_name": "neptune-media-assets" }
  ],
  "ai": { "binding": "AI" },
  "vars": {
    "BOOKING_URL": "https://media.neptunebusiness.com",
    "PUBLIC_ORIGIN": "https://tv.neptunebusiness.com",
    "AI_MODEL": "@cf/openai/gpt-oss-120b",
    "AUTH_FROM_EMAIL": "Neptune Media <connexion@neptunebusiness.com>"
  },
  "observability": { "enabled": true }
}
