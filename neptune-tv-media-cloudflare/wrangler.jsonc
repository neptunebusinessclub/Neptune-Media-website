{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neptune-media-webtv",
  "main": "src/entry-v2.js",
  "compatibility_date": "2026-07-16",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/",
      "/studio/*",
      "/api/*",
      "/emissions/*",
      "/programmes/*",
      "/mentions-legales/*",
      "/confidentialite/*",
      "/contact/*",
      "/robots.txt",
      "/sitemap.xml",
      "/video-sitemap.xml"
    ]
  },
  "durable_objects": {
    "bindings": [
      { "name": "STUDIO", "class_name": "StudioStore" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["StudioStore"] }
  ],
  "ai": { "binding": "AI" },
  "vars": {
    "BOOKING_URL": "https://media.neptunebusiness.com",
    "AI_MODEL": "@cf/openai/gpt-oss-120b"
  },
  "observability": { "enabled": true }
}
